<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:name=".CapAiApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CapAIXML">
        <activity
            android:name=".ui.activities.Splash"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.activities.SignUpScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.LoginScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.HomeScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.EditCaptionScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AutoCaptionScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.GeneratingCaptionScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.ImageDetailsScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.ImageCaptionPreferencesScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.SelectVideoScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.SelectImageScreen"
            android:exported="false" />
        <activity
            android:name=".ui.activities.MainActivity"
            android:exported="true"/>

    </application>

</manifest>